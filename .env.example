APP_NAME="Placówka Online"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Warsaw
APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=placowka_online
# DB_USERNAME=placowka_online
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_EXPIRE_ON_CLOSE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.org"
MAIL_FROM_NAME="${APP_NAME}"

PLACOWKA_MISSING_AFTER_MINUTES=3
PLACOWKA_ALERT_AFTER_MINUTES=5
PLACOWKA_DIAGNOSTIC_INCIDENT_OPEN_AFTER=3
PLACOWKA_DIAGNOSTIC_INCIDENT_RESOLVE_AFTER=5
PLACOWKA_EMAIL_ALERTS_ENABLED=false
PLACOWKA_ALERT_EMAIL_TO=
PLACOWKA_AGENT_PACKAGE_RETENTION_HOURS=24
PLACOWKA_HEARTBEAT_MAX_PAYLOAD_BYTES=262144
PLACOWKA_AGENT_MINIMUM_GO_VERSION=1.26.5
PLACOWKA_AGENT_LATEST_VERSION=exe-1.9.3
PLACOWKA_AGENT_SELF_CHECK_INTERVAL_MINUTES=30
PLACOWKA_AGENT_ALLOW_INTERIM_BUILD=false
PLACOWKA_AGENT_ENROLLMENT_ENABLED=true
PLACOWKA_AGENT_ENROLLMENT_CODE_TTL_MINUTES=15
PLACOWKA_AGENT_ENROLLMENT_SESSION_TTL_MINUTES=10
PLACOWKA_AGENT_ENROLLMENT_TOKEN_REPLAY_MINUTES=5
PLACOWKA_AGENT_ENROLLMENT_MAX_ATTEMPTS=5
PLACOWKA_AGENT_SETUP_VERSION=1.0.6
PLACOWKA_AGENT_INSTALLER_STORAGE_PATH=app/agent-installer/PlacowkaOnlineSetup.exe
PLACOWKA_OFFLINE_QUEUE_MAX_ITEMS=100
PLACOWKA_OFFLINE_QUEUE_MAX_AGE_DAYS=7
PLACOWKA_OFFLINE_QUEUE_FLUSH_PER_CYCLE=10
PLACOWKA_WINDOWS_UPDATE_INTERVAL_MINUTES=720
PLACOWKA_DEFENDER_INTERVAL_MINUTES=360
PLACOWKA_WINDOWS_UPDATE_STALE_DAYS=45
PLACOWKA_DEFENDER_MAX_SIGNATURE_AGE_DAYS=3
PLACOWKA_BACKUP_ENABLED=true
PLACOWKA_BACKUP_RETENTION_DAYS=14
PLACOWKA_LEGACY_AGENT_PACKAGES_ENABLED=false

PLACOWKA_LEGAL_SERVICE_NAME="Placówka Online"
PLACOWKA_LEGAL_SERVICE_URL="http://localhost"
PLACOWKA_LEGAL_CONTROLLER_NAME="Adam Trojanowski"
PLACOWKA_LEGAL_CONTACT_EMAIL="it@it-serwis.net"
PLACOWKA_LEGAL_CONTROLLER_ADDRESS=
PLACOWKA_LEGAL_IOD_EMAIL=
PLACOWKA_SOURCE_CODE_URL="https://github.com/wcagcms/placowka-online"
PLACOWKA_OPEN_SOURCE_LICENSE="GNU AGPL-3.0-or-later"
PLACOWKA_CODE_SIGNING_NAME="Open Source Code Signing"
PLACOWKA_LEGAL_EFFECTIVE_DATE="21 lipca 2026 r."
